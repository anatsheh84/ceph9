# ocp-odf — environment contract
#
#   cp env.sh.example env.sh && $EDITOR env.sh && source env.sh
#
# env.sh is gitignored. Never commit real credentials.

# ────────────────────────────── AWS creds ────────────────────────────────
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""
export AWS_DEFAULT_REGION="us-east-2"

# ────────────────────────────── DNS (REQUIRED for IPI) ───────────────────
# A real public Route 53 hosted zone. Reuse the ceph9 opentlc zone if you have it.
export AWS_BASE_DOMAIN=""              # e.g. sandboxNNNN.opentlc.com
export AWS_ROUTE53_ZONE_ID=""         # e.g. Z3OMFIUXX3RAEI

# ────────────────────────────── Cluster A: ODF INTERNAL ──────────────────
export INT_NAME="ocp-internal"
export INT_REGION="us-east-2"
export INT_MACHINE_CIDR="10.21.0.0/16"   # own VPC
export INT_CLUSTER_CIDR="10.128.0.0/14"  # pod overlay (internal to cluster)
export INT_SERVICE_CIDR="172.30.0.0/16"  # service overlay (internal to cluster)
export INT_WORKER_TYPE="m5.4xlarge"      # internal ODF needs >=16 vCPU workers
export INT_WORKER_REPLICAS="3"

# ────────────────────────────── Cluster B: ODF EXTERNAL ──────────────────
export EXT_NAME="ocp-external"
export EXT_REGION="us-east-2"
export EXT_MACHINE_CIDR="10.22.0.0/16"   # own VPC; MUST NOT overlap ceph VPC (10.20/16)
export EXT_CLUSTER_CIDR="10.132.0.0/14"
export EXT_SERVICE_CIDR="172.31.0.0/16"
export EXT_WORKER_TYPE="m5.2xlarge"      # no internal OSDs → lighter workers ok
export EXT_WORKER_REPLICAS="3"

# Shared sizing
export CONTROL_PLANE_TYPE="m5.xlarge"

# ────────────────────────────── ceph9 VPC (for Phase 2 peering) ──────────
# These match the tags created by ../ansible (aws_infra role, project_tag=ceph9-lab).
export CEPH_REGION="us-east-2"
export CEPH_VPC_CIDR="10.20.0.0/16"
export CEPH_VPC_NAME_TAG="ceph9-lab-vpc"
export CEPH_SG_NAME_TAG="ceph9-lab-sg"

# ────────────────────────────── Static credential paths ──────────────────
export PULL_SECRET_FILE="${HOME}/.openshift/pull-secret.json"
export SSH_PUBLIC_KEY_FILE="${HOME}/.ssh/id_ed25519.pub"
export SSH_PRIVATE_KEY_FILE="${HOME}/.ssh/id_ed25519"

# ────────────────────────────── Versions / behaviour ─────────────────────
export OCP_VERSION="4.21"
export ODF_CHANNEL="stable-4.21"
export PARALLEL_INSTALLS="true"          # install both clusters concurrently

# ────────────────────────────── ceph9 access (Phase 3b external mode) ─────
export CEPH_BASTION_IP=""                    # ceph9 bastion public IP (../ansible/.provisioned.json)
export CEPH_SSH_KEY="${HOME}/.ssh/ceph9-lab.pem"
export CEPH_KNOWN_HOSTS="${HOME}/.ssh/ceph9-known_hosts"
export CEPH_ADMIN_NODE_IP="10.20.2.11"
export CEPH_RBD_POOL="rbd"
export CEPH_FS_NAME="cephfs"
export CEPH_RGW_ENDPOINT="10.20.2.12:8080"
